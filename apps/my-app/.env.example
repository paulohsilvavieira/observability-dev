NODE_ENV=production

# gRPC — traces e metrics (via OTEL Collector)
OTEL_EXPORTER_OTLP_ENDPOINT=https://grpc.ptechsistemas.com

# HTTP — logs (via OTEL Collector → Loki)
OTEL_EXPORTER_OTLP_HTTP_ENDPOINT=https://otel.ptechsistemas.com

# Header de autenticação do Collector (Basic Auth)
# Gerar: echo -n "usuario:senha" | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(user:pass)>

# Identificação do serviço nos traces, logs e métricas
OTEL_SERVICE_NAME=my-nestjs-app

PORT=3000
